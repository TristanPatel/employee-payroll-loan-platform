# Employee Payroll Loan Portal — environment template.
# Copy to `.env.local` (per-app) or `.env` (root) and fill in. NEVER commit secrets.

# ─── Supabase (Phase 1+) ──────────────────────────────────────────────────────
# Public values — safe to expose in browser bundles
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — used by Edge Functions and migration scripts
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# ─── Twilio (Phase 4+) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=

# ─── PAdES signing (Phase 4) ──────────────────────────────────────────────────
# Path to PKCS#12 bundle on the Edge Function host (Supabase Vault in prod)
PADES_SIGNING_P12_PATH=
PADES_SIGNING_P12_PASSWORD=
PADES_TSA_URL=https://freetsa.org/tsr

# ─── App URLs (baked into sealed PDFs — change carefully) ────────────────────
NEXT_PUBLIC_PORTAL_URL=https://portal.richmond-afri.com
NEXT_PUBLIC_VERIFY_URL_BASE=https://portal.richmond-afri.com/verify
NEXT_PUBLIC_SIGNING_CERT_URL=https://www.richmond-afri.com/legal/signing-cert
