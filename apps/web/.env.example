# Richmond Finance — Employee Payroll Loan Portal (web)
#
# Copy this to `.env.local` for local dev, or paste the values into the
# Vercel project settings → Environment Variables for production.
# Never commit `.env.local` or real keys to git.
# ───────────────────────────────────────────────────────────────────────

# Supabase project (these come from the Supabase dashboard → Settings → API)
# The anon key is intended to be public — RLS protects everything.
NEXT_PUBLIC_SUPABASE_URL=https://slmrpvlhttgrhoinpfwa.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNsbXJwdmxodHRncmhvaW5wZndhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg1NzQ2OTcsImV4cCI6MjA5NDE1MDY5N30.vjXF7z6XnpouAlbhk5672YVLBKelnnXlRTKEecFEorY

# Server-only — never expose to the browser. Reach it via process.env.
SUPABASE_SERVICE_ROLE_KEY=<paste from Supabase dashboard → Settings → API>

# URLs embedded into sealed PDFs + verify pages
NEXT_PUBLIC_PORTAL_URL=https://portal.richmond-afri.com
NEXT_PUBLIC_SIGNING_CERT_URL=https://www.richmond-afri.com/legal/signing-cert

# PAdES Baseline-T signing certificate (generate via
# `pnpm tsx scripts/generate-signing-cert.ts`).
# Without these the seal route falls back to soft-seal mode (visible
# signatures + cert of completion, no Adobe signature banner).
PADES_SIGNING_P12_BASE64=
PADES_SIGNING_P12_PASSWORD=
PADES_TSA_URL=https://freetsa.org/tsr
PADES_SIGNER_COMMON_NAME=Richmond Finance Limited
NEXT_PUBLIC_SIGNING_CERT_PEM=
