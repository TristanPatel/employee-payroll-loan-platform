{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "_comment": "Three profiles: development (simulator + Expo Go), preview (internal TestFlight + Google Play internal track), production (App Store + Play Store).",
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "https://slmrpvlhttgrhoinpfwa.supabase.co"
      },
      "ios": { "resourceClass": "m-medium" },
      "android": { "buildType": "apk" }
    },
    "production": {
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "https://slmrpvlhttgrhoinpfwa.supabase.co"
      },
      "autoIncrement": true,
      "ios": { "resourceClass": "m-medium" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "PLACEHOLDER — set after first App Store Connect submission"
      },
      "android": {
        "track": "production",
        "releaseStatus": "draft"
      }
    }
  },
  "update": {
    "_comment": "OTA updates served per channel. preview = internal builds, production = store builds.",
    "fallbackToCacheTimeout": 0
  }
}
